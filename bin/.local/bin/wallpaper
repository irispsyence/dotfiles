#!/bin/bash
export WAYLAND_DISPLAY=${WAYLAND_DISPLAY:-wayland-1}
export XDG_RUNTIME_DIR=${XDG_RUNTIME_DIR:-/run/user/1000}

WALLPAPER="$1"
echo "started with: $WALLPAPER" >> /tmp/wallpaper-debug.log
if [ -z "$WALLPAPER" ]; then
    echo "Usage: wallpaper <path-to-image>"
    exit 1
fi
if [ ! -f "$WALLPAPER" ]; then
    echo "File not found: $WALLPAPER"
    exit 1
fi
echo "file check passed" >> /tmp/wallpaper-debug.log

# Update hyprpaper.conf for persistence across restarts
sed -i "s|preload = .*|preload = $WALLPAPER|" ~/.config/hypr/hyprpaper.conf
sed -i "s|wallpaper = \(.*\),.*|wallpaper = \1,$WALLPAPER|" ~/.config/hypr/hyprpaper.conf

# Apply live via hyprpaper IPC — no restart needed
hyprctl hyprpaper preload "$WALLPAPER"
hyprctl hyprpaper wallpaper ",$WALLPAPER"
echo "hyprpaper wallpaper set via IPC" >> /tmp/wallpaper-debug.log

# Run matugen then let reload.sh handle everything else
{
    matugen image "$WALLPAPER" --mode dark -t scheme-tonal-spot
    sed -i "s|path = .*|path = $WALLPAPER|" ~/.config/hypr/hyprlock.conf
    sed -i "s|background-image: image(url(\".*\"))|background-image: image(url(\"$WALLPAPER\"))|" ~/.config/wlogout/style.css
} &
